<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cine"
                android:textColor="@color/red_accent"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAST"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Items"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Snacks &amp; Drinks"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_snack_item"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            
            <RelativeLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_snack_icon_orange"
                android:gravity="center">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/popcorn"/>
            </RelativeLayout>
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Popcorn"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Large / Buttered"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$8.99"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <android.widget.Button
                    android:id="@+id/btnMinusPopcorn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_minus"
                    android:layout_marginEnd="12dp"/>
                
                <TextView
                    android:id="@+id/txtQtyPopcorn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>
                    
                <android.widget.Button
                    android:id="@+id/btnPlusPopcorn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_plus"/>
            </LinearLayout>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_snack_item"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            
            <RelativeLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_snack_icon_orange"
                android:gravity="center">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/nachos"/>
            </RelativeLayout>
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nachos"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="With Cheese Dip"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$7.99"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <android.widget.Button
                    android:id="@+id/btnMinusNachos"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_minus"
                    android:layout_marginEnd="12dp"/>
                
                <TextView
                    android:id="@+id/txtQtyNachos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>
                    
                <android.widget.Button
                    android:id="@+id/btnPlusNachos"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_plus"/>
            </LinearLayout>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_snack_item"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            
            <RelativeLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_snack_icon_pink"
                android:gravity="center">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/soft_drink"/>
            </RelativeLayout>
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Soft Drink"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Large / Any Flavor"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$5.99"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <android.widget.Button
                    android:id="@+id/btnMinusCola"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_minus"
                    android:layout_marginEnd="12dp"/>
                
                <TextView
                    android:id="@+id/txtQtyCola"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>
                    
                <android.widget.Button
                    android:id="@+id/btnPlusCola"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_plus"/>
            </LinearLayout>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_snack_item"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            
            <RelativeLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_snack_icon_pink"
                android:gravity="center">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/candy_mix"/>
            </RelativeLayout>
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Candy Mix"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assorted Candies"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$6.99"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <android.widget.Button
                    android:id="@+id/btnMinusCandy"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_minus"
                    android:layout_marginEnd="12dp"/>
                
                <TextView
                    android:id="@+id/txtQtyCandy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>
                    
                <android.widget.Button
                    android:id="@+id/btnPlusCandy"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_plus"/>
            </LinearLayout>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_snack_item"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
            
            <RelativeLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_snack_icon_orange"
                android:gravity="center">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/hotdog"/>
            </RelativeLayout>
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hot Dog"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="With Toppings"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$7.99"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <android.widget.Button
                    android:id="@+id/btnMinusHotdog"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="-"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_minus"
                    android:layout_marginEnd="12dp"/>
                
                <TextView
                    android:id="@+id/txtQtyHotdog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>
                    
                <android.widget.Button
                    android:id="@+id/btnPlusHotdog"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_button_plus"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
            
        <TextView
            android:id="@+id/txtFinalTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Payable: $12.00"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/confirm_order"
            android:backgroundTint="@color/red_accent"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:padding="12dp"/>
    </LinearLayout>
</ScrollView>
