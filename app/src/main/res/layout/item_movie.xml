<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_card"
    android:padding="16dp"
    android:layout_marginBottom="16dp">

    <!-- Movie Poster -->
    <ImageView
        android:id="@+id/imgPoster"
        android:layout_width="80dp"
        android:layout_height="110dp"
        android:scaleType="centerCrop"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
    

    <!-- Play text on the right aligned with Title -->
    <TextView
        android:id="@+id/txtPlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Play"
        android:textColor="#B3B3B3"
        android:textSize="14sp"
        android:layout_alignParentEnd="true"
    

    <!-- Content Layout (Title, Genre, Buttons) -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/imgPoster"
        android:layout_toStartOf="@id/txtPlay"
        android:orientation="vertical"
        android:layout_centerVertical="true"
        android:layout_marginEnd="8dp">
    
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtGenreDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#B3B3B3"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBookSeats"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Book Seats"
                android:background="@drawable/bg_button_book"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTrailer"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Trailer"
                android:background="@drawable/bg_button_solid_white"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:drawableStart="@drawable/ic_play_arrow"
                android:drawableTint="@color/black"
                android:drawablePadding="4dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
